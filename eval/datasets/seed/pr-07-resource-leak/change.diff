new file mode 100644
--- /dev/null
+++ b/pkg/store/file.go
@@ -0,0 +1,13 @@
+package store
+
+import "os"
+
+func ReadAll(name string) ([]byte, error) {
+	f, err := os.Open(name)
+	if err != nil {
+		return nil, err
+	}
+	buf := make([]byte, 1024)
+	n, err := f.Read(buf)
+	return buf[:n], err
+}
