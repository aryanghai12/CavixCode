{
  "name": "cavix",
  "version": "0.0.0",
  "private": true,
  "description": "Cavix — AI code review that proves its findings before it speaks.",
  "type": "module",
  "engines": {
    "node": ">=22.7"
  },
  "workspaces": [
    "packages/*",
    "services/orchestrator",
    "eval"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "node --test \"packages/**/test/*.test.ts\" \"services/**/test/*.test.ts\" \"eval/test/*.test.ts\"",
    "demo": "node services/orchestrator/src/demo.ts",
    "phase1": "node packages/pipeline/src/demo.ts",
    "verify-demo": "node packages/verifier/src/demo.ts",
    "orchestrator": "node services/orchestrator/src/main.ts",
    "eval": "node eval/run.ts"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2"
  }
}
